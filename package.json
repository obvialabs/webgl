{
  "sideEffects"       : false,
  "name"              : "@obvia/webgl",
  "description"       : "Lightweight, type‑safe WebGL helpers for shaders, programs, buffers, attributes, textures, and uniforms",
  "keywords"          : ["webgl", "graphics", "gpu", "shader", "program", "buffer", "attribute", "texture", "uniform", "rendering", "3d", "canvas", "utilities", "helpers", "type-safe", "modular", "lightweight", "obvia"],
  "license"           : "MIT",
  "homepage"          : "https://obvia.studio/",
  "version"           : "0.6.0",

  "author"            : {
    "name"  : "Selçuk Çukur",
    "email" : "hello@selcukcukur.me",
    "url"   : "https://selcukcukur.me"
  },

  "bugs"              : {
    "email" : "security@obvia.studio",
    "url"   : "https://github.com/obvialabs/obvia/issues"
  },

  "scripts"           : {
    "build"     : "tsup",
    "dev"       : "tsup --watch",
    "test"      : "vitest",
    "coverage"  : "pnpm test --coverage",
    "clean"     : "rimraf node_modules dist .turbo"
  },

  "types"             : "./dist/index.d.ts",
  "main"              : "./dist/index.cjs",
  "module"            : "./dist/index.mjs",

  "dependencies"      : {},
  "devDependencies"   : {
    "@obvia/presets"            : "^0.0.2",
    "@obvia/utilities"          : "^0.0.4",
    "@types/node"               : "^25.5.0",
    "typescript"                : "^5.9.3",
    "tsup"                      : "^8.5.1",
    "vitest"                    : "^4.0.18",
    "@vitest/coverage-v8"       : "^4.0.18",
    "@vitest/ui"                : "^4.0.18",
    "rimraf"                    : "^6.1.3",
    "jsdom"                     : "^29.0.1"
  },

  "exports"           : {
    "."           : {
      "types"   : "./dist/index.d.ts",
      "import"  : "./dist/index.mjs",
      "require" : "./dist/index.cjs"
    },
    "./attribute" : {
      "types"   : "./dist/attribute/index.d.ts",
      "import"  : "./dist/attribute/index.mjs",
      "require" : "./dist/attribute/index.cjs"
    },
    "./buffer"    : {
      "types"   : "./dist/buffer/index.d.ts",
      "import"  : "./dist/buffer/index.mjs",
      "require" : "./dist/buffer/index.cjs"
    },
    "./canvas"    : {
      "types"   : "./dist/canvas/index.d.ts",
      "import"  : "./dist/canvas/index.mjs",
      "require" : "./dist/canvas/index.cjs"
    },
    "./context"   : {
      "types"   : "./dist/context/index.d.ts",
      "import"  : "./dist/context/index.mjs",
      "require" : "./dist/context/index.cjs"
    },
    "./program"   : {
      "types"   : "./dist/program/index.d.ts",
      "import"  : "./dist/program/index.mjs",
      "require" : "./dist/program/index.cjs"
    },
    "./shader"    : {
      "types"   : "./dist/shader/index.d.ts",
      "import"  : "./dist/shader/index.mjs",
      "require" : "./dist/shader/index.cjs"
    },
    "./texture"   : {
      "types"   : "./dist/texture/index.d.ts",
      "import"  : "./dist/texture/index.mjs",
      "require" : "./dist/texture/index.cjs"
    },
    "./uniform"   : {
      "types"   : "./dist/uniform/index.d.ts",
      "import"  : "./dist/uniform/index.mjs",
      "require" : "./dist/uniform/index.cjs"
    }
  },
  "files"             : ["dist", "readme.md", "license.md"],

  "publishConfig"     : {
    "access"  : "public"
  },
  "publisher"         : {
    "type" : "github",
    "user" : "obvialabs",
    "repo" : "webgl"
  },
  "repository"        : {
    "type"      : "git",
    "url"       : "git+https://github.com/obvialabs/webgl.git"
  }
}
